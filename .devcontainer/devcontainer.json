{
  "name": "Django Dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "web",
  "workspaceFolder": "/app",
  "extensions": [
    "ms-python.python",
    "ms-python.vscode-pylance",
    "njpwerner.autodocstring"
  ],
  "settings": {
    "python.pythonPath": "/usr/local/bin/python",
    "python.formatting.provider": "black"
  }
}
